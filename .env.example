# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# YouTube — RSS works without key (last 15 videos only)
# For full channel history, create a key at Google Cloud Console
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=UCfIOM2FhhCPc8ap9T_NoMjQ
YOUTUBE_CHANNEL_HANDLE=BurakDurgun
NEXT_PUBLIC_YOUTUBE_CHANNEL_HANDLE=BurakDurgun

# Protects /api/sync (set same secret in cron-job.org Authorization header)
CRON_SECRET=generate-a-long-random-string

# npm run sync = tüm videoları parse eder. Cron/API sync = metadata hepsi + parse batch (50/run).
SYNC_PARSE_BATCH_SIZE=50

# Optional: OpenAI for ambiguous titles (future enhancement)
# OPENAI_API_KEY=
