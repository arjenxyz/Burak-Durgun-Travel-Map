# Protects /api/sync (set same secret in cron-job.org Authorization header)
CRON_SECRET=generate-a-long-random-string

# npm run sync uses "full" (API if key set). Vercel /api/sync always uses RSS (cron-safe).
# SYNC_MODE=full

# Optional: OpenAI for ambiguous titles (future enhancement)
